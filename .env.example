# ==========================================
# Octopus 全局配置文件 (.env)
# 
# 使用说明：
# 1. 将此文件复制一份并重命名为 `.env` (注意有个点，且没有后缀名)
# 2. 根据您的情况，修改下方的值。
# 3. 以后直接运行 python demo/test_llm.py 即可，无需再敲命令行环境变量！
# ==========================================

# 1. 大模型提供商 (可填: openai, ollama, mock)
# 如果不想配置任何模型直接看代码流转，请填 mock
OCTOPUS_LLM_PROVIDER=mock

# 2. 模型名称
# openai 的推荐填法: gpt-4o, deepseek-chat 等
# ollama 的推荐填法: llama3, qwen 等
OCTOPUS_LLM_MODEL=gpt-4o

# ==========================================
# [如果 Provider 是 openai 则必填]
# ==========================================
# 您的 API 密钥 (如果是本地测试可随便填)
OCTOPUS_OPENAI_API_KEY=sk-your-api-key-here
# (可选) 第三方中转代理或兼容API地址，如: https://api.deepseek.com/v1
# 留空则默认请求官方 openai 接口
# OCTOPUS_OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# [如果 Provider 是 ollama 则必填]
# ==========================================
# Ollama 服务的本地地址 (通常默认就是这个，不需要改)
OCTOPUS_OLLAMA_BASE_URL=http://localhost:11434
